{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["chrome", "vite/client"]
  },
  "include": [
    "popup.html",
    "src",
    "scripts",
    "tests",
    "vite.config.ts",
    "eslint.config.js"
  ]
}
