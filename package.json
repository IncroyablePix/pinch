{
  "name": "pinch",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-browser extension scaffold for Chromium and Firefox.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "vite build --watch --mode chromium",
    "dev:chromium": "vite build --watch --mode chromium",
    "dev:firefox": "vite build --watch --mode firefox",
    "build": "npm run clean && npm run build:chromium && npm run build:firefox",
    "build:chromium": "vite build --mode chromium",
    "build:firefox": "vite build --mode firefox",
    "pack": "npm run build && node scripts/pack.mjs chromium && node scripts/pack.mjs firefox",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "prepare": "simple-git-hooks"
  },
  "lint-staged": {
    "*.{css,html,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/chrome": "^0.0.321",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "archiver": "^7.0.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
